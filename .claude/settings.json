{
  "enabledPlugins": {
    "expo@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(npm run verify)",
      "Bash(npm run lint*)",
      "Bash(npm run typecheck)",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run docs:lint)",
      "Bash(npx expo *)"
    ],
    "deny": ["Read(.env)", "Read(.env.*)", "Bash(git push --force*)", "Bash(eas credentials*)"]
  }
}
